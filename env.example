# .env.example — copy to .env and fill in real values
# never commit .env to git
#
# GENERATING JWT_SECRET_KEY
# Use this command on the terminal:
# python -c "import secrets; print(secrets.token_hex(32))"

# --- Database ---
DB_NAME=inventory.db

# --- JWT ---
JWT_SECRET_KEY=your-strong-random-secret-here
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Rate Limiting ---
DEFAULT_RATE_LIMIT=200 per hour
LOGIN_RATE_LIMIT=10 per minute
REGISTER_RATE_LIMIT=5 per minute
WRITE_RATE_LIMIT=30 per minute
READ_RATE_LIMIT=60 per minute

# --- App ---
FLASK_DEBUG=true
HOST=0.0.0.0
PORT=4999
